<Window x:Class="FileSyncInspector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FileSyncInspector"
        xmlns:properties="clr-namespace:FileSyncInspector.Properties"
        mc:Ignorable="d"
        Height="650" Width="1000" Title="{x:Static properties:Strings.WindowTitle}"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Výběr složek -->
            <RowDefinition Height="Auto"/>
            <!-- Akce a Progress -->
            <RowDefinition Height="*"/>
            <!-- Výsledky (zabírá zbylé místo) -->
        </Grid.RowDefinitions>

        <!-- 1. SEKCE: Výběr složek -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Zdrojová karta -->
            <Border Grid.Column="0" Background="{StaticResource CardBackground}" CornerRadius="8" Padding="15">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{x:Static properties:Strings.SourceFolder}" Style="{StaticResource HeaderTextStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="TextBoxSourceFolder" Grid.Column="0" IsReadOnly="True" Margin="0,0,10,0"/>
                        <Button Name="ButtonBrowseSource" Grid.Column="1" Content="{x:Static properties:Strings.Browse}" Width="100" Click="ButtonBrowseSource_Click" Style="{StaticResource SecondaryButton}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Cílová karta -->
            <Border Grid.Column="2" Background="{StaticResource CardBackground}" CornerRadius="8" Padding="15">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="{x:Static properties:Strings.TargetFolder}" Style="{StaticResource HeaderTextStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="TextBoxTargetFolder" Grid.Column="0" IsReadOnly="True" Margin="0,0,10,0"/>
                        <Button Name="ButtonBrowseTarget" Grid.Column="1" Content="{x:Static properties:Strings.Browse}" Width="100" Click="ButtonBrowseTarget_Click" Style="{StaticResource SecondaryButton}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 2. SEKCE: Ovládací tlačítka a ProgressBar -->
        <Border Grid.Row="1" Background="{StaticResource CardBackground}" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Name="ButtonStart" Grid.Column="0" Content="{x:Static properties:Strings.StartComparison}" Width="160" Click="ButtonStart_Click" IsEnabled="False" />
                <Button Name="ButtonCancel" Grid.Column="1" Content="{x:Static properties:Strings.Cancel}" Width="100" Margin="10,0,0,0" Click="ButtonCancel_Click" IsEnabled="False" Style="{StaticResource SecondaryButton}"/>

                <!-- UPRAVENÝ STACKPANEL PRO PROGRESS A TEXT -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="20,0,20,0">
                    <TextBlock Text="{x:Static properties:Strings.AnalysisProgress}" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,0,5"/>
                    <ProgressBar Name="ProgressBarComparison" Height="8" />
                    <!-- NOVÉ: Indikátor aktuálního souboru/složky -->
                    <TextBlock Name="TextBlockCurrentOperation" Text="..." FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,5,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                </StackPanel>

                <Button Grid.Column="3" Content="{x:Static properties:Strings.ToggleView}" Width="150" Click="ToggleView_Click" Style="{StaticResource SecondaryButton}"/>
            </Grid>
        </Border>

        <!-- 3. SEKCE: Výsledky porovnání -->
        <Grid Grid.Row="2">

            <!-- TEXTOVÝ VÝSTUP -->
            <Grid x:Name="TextOutputPanel" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource CardBackground}" CornerRadius="8" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{x:Static properties:Strings.SourceOutput}" Style="{StaticResource HeaderTextStyle}"/>
                        <TextBox Name="TextBoxSourceOutput" IsReadOnly="True" AcceptsReturn="True" 
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="Wrap" Background="#F9F9F9"/>
                    </DockPanel>
                </Border>

                <Border Grid.Column="2" Background="{StaticResource CardBackground}" CornerRadius="8" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{x:Static properties:Strings.TargetOutput}" Style="{StaticResource HeaderTextStyle}"/>
                        <TextBox Name="TextBoxTargetOutput" IsReadOnly="True" AcceptsReturn="True" 
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="Wrap" TextChanged="TextBoxTargetOutput_TextChanged" Background="#F9F9F9"/>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- TREEVIEW VÝSTUP -->
            <Grid x:Name="TreeViewPanel" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource CardBackground}" CornerRadius="8" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{x:Static properties:Strings.SourceTree}" Style="{StaticResource HeaderTextStyle}"/>
                        <TreeView Name="TreeViewSourceOutput" BorderThickness="1" BorderBrush="{StaticResource BorderColor}" Background="#FAFAFA" Padding="5"/>
                    </DockPanel>
                </Border>

                <Border Grid.Column="2" Background="{StaticResource CardBackground}" CornerRadius="8" Padding="15">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{x:Static properties:Strings.TargetTree}" Style="{StaticResource HeaderTextStyle}"/>
                        <TreeView Name="TreeViewTargetOutput" BorderThickness="1" BorderBrush="{StaticResource BorderColor}" Background="#FAFAFA" Padding="5"/>
                    </DockPanel>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</Window>